  "keyFeatures": [
    "Custom player model creation using Blockbench",
    "Optional Lua scripting API for dynamic avatar behavior",
    "Server-side visibility without requiring server mods",
    "Robust permission and trust system for safety",
    "Action wheel for in-game interactive controls",
    "Ping system for syncing events across all players",
    "Emissive textures and advanced rendering options",
    "Support for Fabric, Forge, Quilt, and NeoForge"
  ],
  "publicApiSurface": [
    "events.TICK",
    "events.RENDER",
    "events.ENTITY_INIT",
    "events.KEY_PRESS",
    "events.CHAT_SEND_MESSAGE",
    "events.MOUSE_PRESS",
    "events.USE_ITEM",
    "avatar.getNBT()",
    "avatar.store(key, value)",
    "pings.<name>(...)",
    "animations.<model>.<name>:play()",
    "vanilla_model.ALL:setVisible(bool)",
    "vanilla_model.PLAYER:setVisible(bool)",
    "vanilla_model.ARMOR:setVisible(bool)",
    "action_wheel:newPage()",
    "action_wheel:newAction()",
    "renderer:setRenderType(type)",
    "keybinds:newKeybind(name, key)",
    "nameplate.ENTITY:setText(text)",
    "sounds:playSound(id, pos, volume, pitch)",
    "particles:addParticle(id, pos, vel)",
    "world.getBiome(pos)",
    "host:setUnlockCursor(bool)"
  ]
